rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /usuarios/{userId} {
      allow read, write: if true;
    }
    match /documentos/{docId} {
      allow read, write: if true;
    }
    match /configuracion/{configId} {
      allow read, write: if true;
    }
    match /zonas/{zonaId} {
      allow read, write: if true;
    }
  }
}
